@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<MudPaper Elevation="2" Class="pa-6 counter-card">
    <MudText Typo="Typo.h4" Color="Color.Primary" GutterBottom="true">Counter</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">Tap the button to increment your count.</MudText>

    <MudStack Direction="Direction.Row" AlignItems="AlignItems.Center" Spacing="3">
        <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Large">@currentCount</MudAvatar>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="IncrementCount">
            Add one
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="ResetCount">
            Reset
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private int currentCount;

    private void IncrementCount()
    {
        currentCount++;
    }

    private void ResetCount()
    {
        currentCount = 0;
    }
}
