@page "/"

<PageTitle>Home</PageTitle>

<MudGrid Spacing="4">
    <MudItem xs="12" md="8">
        <MudPaper Elevation="2" Class="pa-6">
            <MudText Typo="Typo.h3" GutterBottom="true" Color="Color.Primary">Welcome to Whatever</MudText>
            <MudText Typo="Typo.body1" Class="mb-4">
                A cozy Blazor + MudBlazor starter with an earthy palette inspired by clay, moss, and warm sunlight.
            </MudText>
            <MudChipSet T="string" Class="mb-4" AllClosable="false">
                <MudChip T="string" Value='@("MudBlazor")' Color="Color.Primary" Variant="Variant.Filled">MudBlazor</MudChip>
                <MudChip T="string" Value='@("Blazor Server")' Color="Color.Secondary" Variant="Variant.Filled">Blazor Server</MudChip>
                <MudChip T="string" Value='@("Earthy Theme")' Color="Color.Tertiary" Variant="Variant.Filled">Earthy Theme</MudChip>
            </MudChipSet>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/weather" StartIcon="@Icons.Material.Filled.Explore">Explore Weather</MudButton>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudPaper Elevation="1" Class="pa-4 h-100">
            <MudText Typo="Typo.h6" GutterBottom="true" Color="Color.Secondary">Quick Links</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Href="/counter" Icon="@Icons.Material.Filled.AddCircle">Try the counter</MudListItem>
                <MudListItem T="string" Href="/weather" Icon="@Icons.Material.Filled.Cloud">View sample forecast</MudListItem>
                <MudListItem T="string" Href="https://mudblazor.com" Target="_blank" Icon="@Icons.Material.Filled.Launch">MudBlazor docs</MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>
