@inherits LayoutComponentBase

<MudThemeProvider Theme="@EarthyTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Surface" Dense="true" Class="app-bar">
        <MudText Typo="Typo.h6" Color="Color.Primary">Whatever</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Text"
                   Color="Color.Secondary"
                   Href="https://learn.microsoft.com/aspnet/core/"
                   Target="_blank"
                   StartIcon="@Icons.Material.Filled.MenuBook"
                   Class="me-2">
            Learn Blazor
        </MudButton>
        <AuthorizeView>
            <NotAuthorized>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/login" Class="me-2">
                    Login
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/register">
                    Register
                </MudButton>
            </NotAuthorized>
            <Authorized Context="authState">
                <MudChip T="string" Color="Color.Tertiary" Variant="Variant.Outlined" Class="me-2">
                    @authState.User.Identity?.Name
                </MudChip>
                <form method="post" action="/account/logout">
                    <input type="hidden" name="returnUrl" value="/" />
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" ButtonType="ButtonType.Submit">
                        Logout
                    </MudButton>
                </form>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer Open="true" Elevation="1" ClipMode="DrawerClipMode.Always" Color="Color.Primary" Class="sidebar-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="content-shell py-6 px-6">
            <AuthorizeView>
                <Authorized Context="authState">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                        Logged in as @authState.User.Identity?.Name
                    </MudAlert>
                </Authorized>
            </AuthorizeView>
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static readonly MudTheme EarthyTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#5c6b3f",
            Secondary = "#a1683a",
            Tertiary = "#7b8364",
            Background = "#f3ede3",
            Surface = "#fffaf3",
            AppbarBackground = "#fffaf3",
            DrawerBackground = "#6f4e37",
            DrawerText = "#f8f1e5",
            TextPrimary = "#2f2a24",
            TextSecondary = "#6c6256"
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft = "280px"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" }
            }
        }
    };
}
